#alias -='cd -'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias _='sudo'
alias add='vim ~/.bash_aliases'
alias agi='sudo apt-get install -y'
alias back='cd /home/howlin/workspace/head/backpack'
alias box='cd /home/howlin/workspace/sandbox'
alias c='clear'
alias cork='cd /home/howlin/workspace/head/corkboard'
alias dl='cd /home/howlin/Downloads'
alias forget='cd /run/media/howlin/forgetterbox'
alias gh='history | grep'
alias gits='cd /home/howlin/workspace/gits'
alias h='history'
alias irc=''
alias l='ls -a'
alias l.='ls -d .*'
alias l.l='ls -dl .*'
alias l1='ls -1'
alias la='ls -A'
alias lal='ls -Alh'
alias ll='ls -l'
alias ls='ls --color=auto'
alias md='mkdir -p'
alias naut='nautilus --browser'
alias pmd='sudo pacman -Rs'
alias pmg='sudo pacman -Qe | grep'
alias pms='sudo pacman -S'
alias pmu='sudo pacman -Syu'
alias q='exit'
alias rd='rm -rf'
alias reload='source ~/.bashrc'
alias usb='cd /run/media/howlin'
alias wh='cd /home/howlin/workspace/head'
alias work='cd /home/howlin/workspace'
alias ~='cd ~'
alias play='cd /home/howlin/cupboard/sandpit'
alias fs='cat /home/howlin/corkboard/my-fs.md'
alias finds='echo "find . -iname \"*string*\""'
alias fig='/usr/bin/git --git-dir=$HOME/.fig/ --work-tree=$HOME'
