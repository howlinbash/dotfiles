#!/usr/bin/python3

import datetime, os

time_stamp = datetime.datetime.now().strftime('%Y-%m-%d-%H:%M:%S')

class Backup(object):
    def __init__(self, data, repo, excludes):
        self.data      = data
        self.repo      = repo
        self.excludes  = excludes

    def make_cmd(self):
        options = "create --stats --progress --compression lz4"
        excludes = ""

        for i in self.excludes:
            excludes = excludes + "--exclude " + self.data + i + " "

        command = "borg " + options + " " + self.repo + "::" + time_stamp + " " + self.data + " " + excludes

        return command

    def print_cmd(self):
        print(self.make_cmd())

def make_backup(data, repo, excludes):
    backup = Backup(data, repo, excludes)
    return backup

backup_home = make_backup(
    "/home/howlin/", 
    "/media/elephant/backups/wolf/home/", 
    ["Videos", "VirtualBox\ VMs", "Music"]
)

backup_root = make_backup(
    "/", 
    "/media/elephant/backups/wolf/root/", 
    ["dev", "home", "lost+found", "mnt", "media", "proc", "run", "sys", "tmp", "var/lib/docker"]
)

print(time_stamp)
print("\nhome:")
backup_home.print_cmd() 
print("\nroot:")
backup_root.print_cmd() 
